{
  "manifest_version": 3,
  "name": "Patient Summary",
  "version": "1.0",
  "description": "Quick Suite patient record reviewer",

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Open Patient Summary"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "128": "icon.png"
  }
}
